# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by the app at runtime.
# Supabase (serverless/Vercel): use the POOLED connection (port 6543) and add ?pgbouncer=true
#   e.g. postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/website_status?schema=public"
# Direct (non-pooled) connection used for migrations / db push.
# Supabase: use the DIRECT connection (port 5432). For local dev, set this to the same as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/website_status?schema=public"
# Strong random secret used to sign session JWTs (required in production, min 16 chars)
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
# Public base URL of the app (used in emails and OAuth redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# How often the long-running worker wakes up to check due monitors (cron syntax)
WORKER_CRON="* * * * *"
# Shared secret required to call the /api/cron endpoint (optional but recommended)
CRON_SECRET=""

# ─── Email (optional) ─────────────────────────────────────────────────────────
# Transactional email via Resend (https://resend.com). If unset, email alerts and
# verification/reset emails are skipped gracefully (logged, not sent).
RESEND_API_KEY=""
EMAIL_FROM="WebsiteStatus <alerts@yourdomain.com>"

# ─── GitHub OAuth (optional) ──────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Expose the client id to the browser so the "Continue with GitHub" button appears
NEXT_PUBLIC_GITHUB_CLIENT_ID=""

# ─── Seed (optional) ──────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin12345"
